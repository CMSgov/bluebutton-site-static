        "short": "ExplanationOfBenefit-Pharmacy",
        "definition": "ExplanationOfBenefit-Pharmacy"
      },
      {
        "id": "ExplanationOfBenefit-Pharmacy.lastUpdated",
        "path": "ExplanationOfBenefit-Pharmacy.lastUpdated",
        "short": "Last Updated Time",
        "definition": "This field represents the last time that an ExplanationOfBenefit was updated.",
        "min": 0,
        "max": "1",
        "type": [
          {
            "code": "string"
          }
        ]
      },
      {
        "id": "ExplanationOfBenefit-Pharmacy.BENE_SK",
        "path": "ExplanationOfBenefit-Pharmacy.BENE_SK",
        "short": "Beneficiary Source Key - On Claim",
        "definition": "Beneficiary Source Key - On Claim",
        "min": 1,
        "max": "1",
        "type": [
          {
            "code": "string"
          }
        ]
      },
      {
        "id": "ExplanationOfBenefit-Pharmacy.CLM_TYPE_CD",
        "path": "ExplanationOfBenefit-Pharmacy.CLM_TYPE_CD",
        "short": "Claim Type Code",
        "definition": "A code identifying the source and type of claim submitted through the Medicare or Medicaid program. For example: 60 = Medicare National Claims History (NCH) inpatient claim. 8900 = Medicaid fee for service dental. Reference table: CLM_TYPE_CD",
        "min": 1,
        "max": "1",
        "type": [
          {
            "code": "integer"
          }
        ]
      },
      {
        "id": "ExplanationOfBenefit-Pharmacy.CLM_UNIQ_ID",
        "path": "ExplanationOfBenefit-Pharmacy.CLM_UNIQ_ID",
        "short": "Claim Unique ID",
        "definition": "An Integrated Data Repository (IDR) assigned surrogate key used to identify a claim.",
        "min": 1,
        "max": "1",
        "type": [
          {
            "code": "string"
          }
        ]
      },
      {
        "id": "ExplanationOfBenefit-Pharmacy.CLM_CNTL_NUM",
        "path": "ExplanationOfBenefit-Pharmacy.CLM_CNTL_NUM",
        "short": "Claim Control Number",
        "definition": "This field is an identification value assigned by a MAC. It provides a reference number for the control and monitoring of specific claims, and to differentiate between claims for the beneficiary.",
        "min": 1,
        "max": "1",
        "type": [
          {
            "code": "string"
          }
        ]
      },
      {
        "id": "ExplanationOfBenefit-Pharmacy.CLM_ORIG_CNTL_NUM",
        "path": "ExplanationOfBenefit-Pharmacy.CLM_ORIG_CNTL_NUM",
        "short": "Original Claim Control Number",
        "definition": "This field contains the original claim control number for adjusted or corrected claims. It provides a reference to the prior claim that this claim is adjusting or correcting.",
        "min": 0,
        "max": "1",
        "type": [
          {
            "code": "string"
          }
        ]
      },
      {
        "id": "ExplanationOfBenefit-Pharmacy.CLM_FROM_DT",
        "path": "ExplanationOfBenefit-Pharmacy.CLM_FROM_DT",
        "short": "Claim From Date",
        "definition": "A date identifying the first day services are provided to a beneficiary.",
        "min": 1,
        "max": "1",
        "type": [
          {
            "code": "string"
          }
        ]
      },
      {
        "id": "ExplanationOfBenefit-Pharmacy.CLM_THRU_DT",
        "path": "ExplanationOfBenefit-Pharmacy.CLM_THRU_DT",
        "short": "Claim Thru Date",
        "definition": "A date identifying the last day services are provided to a beneficiary. Note: For drug claims, this date is when the prescription was filled.",
        "min": 1,
        "max": "1",
        "type": [
          {
            "code": "string"
          }
        ]
      },
      {
        "id": "ExplanationOfBenefit-Pharmacy.CLM_EFCTV_DT",
        "path": "ExplanationOfBenefit-Pharmacy.CLM_EFCTV_DT",
        "short": "Claim Effective Date",
        "definition": "A date corresponding to the National Claim History (NCH) weekly processing date and used in final action processing to identify a version of a claim. It will always be a Friday date.",
        "min": 1,
        "max": "1",
        "type": [
          {
            "code": "string"
          }
        ]
      },
      {
        "id": "ExplanationOfBenefit-Pharmacy.CLM_SRC_ID",
        "path": "ExplanationOfBenefit-Pharmacy.CLM_SRC_ID",
        "short": "Claim Source ID",
        "definition": "An identifier indicating where the source of the claim data in the Integrated Data Repository (IDR) originated from. Valid values: 20000 = National Claims History (NCH). 21000 = Fiscal Intermediary Shared System (FISS). 22000 = Multi-Carrier System (MCS). 23000 = Viable Information Processing Systems (VIPS) Medicare System (VMS). 24000 = Encounter Data Processing System (EDPS). 25000 = Encounter Medicaid Duals 837 claims and Duals Medicaid Drug Claims (DMDC). N/A = Medicaid",
        "min": 1,
        "max": "1",
        "type": [
          {
            "code": "string"
          }
        ]
      },
      {
        "id": "ExplanationOfBenefit-Pharmacy.META_SRC_SK",
        "path": "ExplanationOfBenefit-Pharmacy.META_SRC_SK",
        "short": "Source ID",
        "definition": "Identifies the source system of the ExplanationOfBenefit data.",
        "min": 1,
        "max": "1",
        "type": [
          {
            "code": "string"
          }
        ]
      },
      {
        "id": "ExplanationOfBenefit-Pharmacy.PRVDR_SRVC_PRVDR_NPI_NUM",
        "path": "ExplanationOfBenefit-Pharmacy.PRVDR_SRVC_PRVDR_NPI_NUM",
        "short": "Service Provider NPI Number",
        "definition": "A number identifying the National Provider Identifier (NPI) of a service provider as sourced from the NPI crosswalk reference information provided by the National Plan and Provider Enumeration System (NPPES).",
        "min": 0,
        "max": "1",
        "type": [
          {
            "code": "string"
          }
        ]
      },
      {
        "id": "ExplanationOfBenefit-Pharmacy.CLM_PD_DT",
        "path": "ExplanationOfBenefit-Pharmacy.CLM_PD_DT",
