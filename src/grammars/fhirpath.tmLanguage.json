{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Fhirpath",
  "scopeName": "source.fhirpath",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#datetime" },
    { "include": "#keywords" },
    { "include": "#quantities" },
    { "include": "#operators" },
    { "include": "#variables" },
    { "include": "#constants" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.fhirpath",
          "begin": "/\\*",
          "end": "\\*/"
        },
        {
          "name": "comment.line.double-slash.fhirpath",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.single.fhirpath",
      "begin": "'",
      "end": "'",
      "patterns": [
        {
          "name": "constant.character.escape.fhirpath",
          "match": "\\\\(?:u[0-9A-Fa-f]{4}|[`'\\\\/fnrt])"
        },
        {
          "name": "invalid.illegal.unrecognized-string-escape.fhirpath",
          "match": "\\\\."
        }
      ]
    },
    "datetime": {
      "patterns": [
        {
          "name": "constant.other.datetime.fhirpath",
          "match": "@[0-9]{4}(?:-[0-9]{2}(?:-[0-9]{2})?)?T(?:[0-9]{2}(?::[0-9]{2}(?::[0-9]{2}(?:\\.[0-9]+)?)?)?(?:Z|[+-][0-9]{2}:[0-9]{2})?)?"
        },
        {
          "name": "constant.other.time.fhirpath",
          "match": "@T[0-9]{2}(?::[0-9]{2}(?::[0-9]{2}(?:\\.[0-9]+)?)?)?"
        },
        {
          "name": "constant.other.date.fhirpath",
          "match": "@[0-9]{4}(?:-[0-9]{2}(?:-[0-9]{2})?)?"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.fhirpath.existence",
          "match": "\\b(empty|exists|all|allTrue|anyTrue|allFalse|anyFalse|subsetOf|supersetOf|count|distinct|isDistinct)\\b(?=\\s*\\()"
        },
        {
          "name": "keyword.control.fhirpath.filtering",
          "match": "\\b(where|select|repeat|ofType)\\b(?=\\s*\\()"
        },
        {
          "name": "keyword.control.fhirpath.subsetting",
          "match": "\\b(single|first|last|tail|skip|take|intersect|exclude)\\b(?=\\s*\\()"
        },
        {
          "name": "keyword.control.fhirpath.combining",
          "match": "\\b(union|combine)\\b(?=\\s*\\()"
        },
        {
          "name": "keyword.control.fhirpath.conversion",
          "match": "\\b(iif|toBoolean|convertsToBoolean|toInteger|convertsToInteger|toDate|convertsToDate|toDateTime|convertsToDateTime|toDecimal|convertsToDecimal|toQuantity|convertsToQuantity|toString|convertsToString|toTime|convertsToTime)\\b(?=\\s*\\()"
        },
        {
          "name": "keyword.control.fhirpath.strings",
          "match": "\\b(indexOf|substring|startsWith|endsWith|contains|upper|lower|replace|matches|replaceMatches|length|toChars|split|join|encode|decode|trim|matchesFull)\\b(?=\\s*\\()"
        },
        {
          "name": "keyword.control.fhirpath.math",
          "match": "\\b(abs|ceiling|exp|floor|ln|log|power|round|sqrt|truncate)\\b(?=\\s*\\()"
        },
        {
          "name": "keyword.control.fhirpath.treenav",
          "match": "\\b(children|descendants)\\b(?=\\s*\\()"
        },
        {
          "name": "keyword.control.fhirpath.utility",
          "match": "\\b(trace|now|timeOfDay|today|not|defineVariable|lowBoundary|highBoundary|precision)\\b(?=\\s*\\()"
        },
        {
          "name": "keyword.control.fhirpath.types",
          "match": "\\b(is|as|type)\\b(?=\\s*\\()"
        },
        {
          "name": "keyword.control.fhirpath.aggregate",
          "match": "\\b(aggregate)\\b(?=\\s*\\()"
        },
        {
          "name": "support.function.fhirpath.fhir",
          "match": "\\b(extension|hasValue|getValue|resolve|elementDefinition|slice|checkModifiers|conformsTo|memberOf|subsumes|subsumedBy|htmlChecks|comparable|hasTemplateIdOf|weight)\\b(?=\\s*\\()"
        },
        {
          "match": "\\b(is|as)\\b\\s+([A-Za-z_][A-Za-z0-9_]*(?:\\.[A-Za-z_][A-Za-z0-9_]*)*)",
          "captures": {
            "1": { "name": "keyword.operator.word.fhirpath" },
            "2": { "name": "support.type.fhirpath" }
          }
        },
        {
          "name": "keyword.operator.word.fhirpath",
          "match": "\\b(in|contains|and|or|xor|implies|div|mod)\\b"
        }
      ]
    },
    "quantities": {
      "patterns": [
        {
          "match": "(\\b[0-9]+(?:\\.[0-9]+)?)\\s+(years|year|months|month|weeks|week|days|day|hours|hour|minutes|minute|seconds|second|milliseconds|millisecond)\\b",
          "captures": {
            "1": { "name": "constant.numeric.fhirpath" },
            "2": { "name": "keyword.other.unit.fhirpath" }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.fhirpath",
          "match": "!=|!~|<=|>=|~|=|<|>"
        },
        {
          "name": "keyword.operator.arithmetic.fhirpath",
          "match": "\\+|-|\\*|/|&"
        },
        {
          "name": "keyword.operator.union.fhirpath",
          "match": "\\|"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.language.fhirpath.environment",
          "match": "%`(?:\\\\.|[^`])*`"
        },
        {
          "name": "variable.language.fhirpath.environment",
          "match": "%[A-Za-z_][A-Za-z0-9_]*"
        },
        {
          "name": "variable.language.fhirpath.special",
          "match": "\\$(this|index|total)\\b"
        },
        {
          "name": "variable.other.fhirpath.delimited",
          "match": "`(?:\\\\.|[^`])*`"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.empty.fhirpath",
          "match": "\\{\\s*\\}"
        },
        {
          "name": "constant.language.boolean.fhirpath",
          "match": "\\b(?:true|false)\\b"
        },
        {
          "name": "constant.numeric.fhirpath",
          "match": "\\b[0-9]+(?:\\.[0-9]+)?\\b"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.accessor.fhirpath",
          "match": "\\."
        },
        {
          "name": "punctuation.separator.comma.fhirpath",
          "match": ","
        },
        {
          "name": "punctuation.section.parens.begin.fhirpath",
          "match": "\\("
        },
        {
          "name": "punctuation.section.parens.end.fhirpath",
          "match": "\\)"
        },
        {
          "name": "punctuation.section.brackets.begin.fhirpath",
          "match": "\\["
        },
        {
          "name": "punctuation.section.brackets.end.fhirpath",
          "match": "\\]"
        }
      ]
    }
  }
}
