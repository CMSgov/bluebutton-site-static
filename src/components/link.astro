---
import { $path } from 'astro-typesafe-routes/path'
import { button } from '#utils/cva/button'
import type { RouteId, RouteOptions } from 'astro-typesafe-routes/path'
import type { HTMLAttributes } from 'astro/types'
import type { VariantProps } from 'cva'
import { withTrailingSlash } from '#utils/trailing-slash'
import type { HrefOrTo } from '#utils/types'
import Icon from './icon.astro'
import FileDownload from '@uswds/uswds/img/usa-icons/file_download.svg'
import { internalToRelativeUrl } from '#utils/internal-to-relative-url'

type Props<T extends RouteId> = Omit<HTMLAttributes<'a'>, 'href'> &
  VariantProps<typeof button> & {
    showIcon?: boolean
  } & HrefOrTo<T>

const downloadExtsRegex =
  /\.(doc|docx|xls|xlsx|xlsm|ppt|pptx|exe|zip|pdf|js|txt|csv|dxf|dwgd|rfa|rvt|dwfx|dwg|wmv|jpg|msi|7z|gz|tgz|wma|mov|avi|mp3|mp4|csv|mobi|epub|swf|rar|json)$/

const props = Astro.props as Props<RouteId>

let isExternal = false
let isDownload = false
let computedHref: string

if ('to' in props && props.to) {
  // Explicit internal link using "to" prop (preferred for Astro templates)
  isExternal = false
  computedHref = $path(props as unknown as RouteOptions<RouteId>) // Type assertion needed to satisfy both RouteOptions and HrefOrTo
} else if ('href' in props && props.href) {
  // Handle href - could be external or internal (from MDX)
  const hrefString = props.href.toString()

  // Check if it's an external URL
  if (hrefString.startsWith('http')) {
    isExternal = true
    computedHref = hrefString
  } else {
    // Internal link (from MDX)
    isExternal = false
    computedHref = hrefString
  }
} else {
  throw new Error('Link component requires either "href" or "to" prop')
}

if (isExternal === false && downloadExtsRegex.test(computedHref)) {
  isDownload = true
}

const { variant = 'link', size, showIcon = true, class: className, ...restProps } = props

computedHref = internalToRelativeUrl(computedHref) // Convert internal, absolute URLs to relative
computedHref = withTrailingSlash(computedHref) // Normalize trailing slashes
---

<a
  href={computedHref}
  target={isExternal || isDownload ? '_blank' : undefined}
  rel={isExternal && !computedHref?.includes('cms.gov') ? 'noreferrer' : undefined}
  class:list={[button({ variant, size }), isExternal && showIcon ? 'usa-link--external' : '', className]}
  data-tealium={isDownload ? 'download' : undefined}
  {...restProps}><slot />{isDownload ? <Icon icon={FileDownload} size={2} class="margin-left-05" /> : null}</a
>
