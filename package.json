{
  "name": "bluebutton-static-site",
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && astro build && pagefind --site dist",
    "preview": "astro preview",
    "sync": "astro sync",
    "astro": "astro",
    "lint": "eslint 'src/**/*.{astro,js,jsx,ts,tsx,md,mdx,json}'",
    "lint:fix": "eslint 'src/**/*.{astro,js,jsx,ts,tsx,md,mdx,json}' --fix",
    "lint:linkcheck": "astro build && tsm --require=./scripts/linkcheck/lib/filter-warnings.cjs ./scripts/linkcheck/index.ts",
    "typecheck": "astro check",
    "spellcheck": "cspell",
    "update:npm": "npx taze -w"
  },
  "dependencies": {
    "@astrojs/mdx": "^6.0.3",
    "@astrojs/preact": "^5.1.5",
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource-variable/open-sans": "^5.2.7",
    "@uswds/uswds": "3.12.0",
    "astro": "^6.4.7",
    "astro-expressive-code": "^0.43.1",
    "astro-seo": "^1.1.0",
    "astro-typesafe-routes": "^5.1.0",
    "cva": "^1.0.0-beta.4",
    "fast-xml-parser": "^5.9.0",
    "papaparse": "^5.5.3",
    "preact": "^10.29.2",
    "prettier-plugin-astro": "^0.14.1",
    "sass-embedded": "^1.100.0",
    "tinyglobby": "^0.2.17"
  },
  "devDependencies": {
    "@actions/core": "^3.0.1",
    "@antfu/eslint-config": "^9.0.0",
    "@astrojs/check": "^0.9.9",
    "@astrojs/ts-plugin": "^1.10.9",
    "@eslint-react/eslint-plugin": "^5.9.0",
    "@types/papaparse": "^5.5.2",
    "@uswds/compile": "^1.3.2",
    "astro-eslint-parser": "^1.4.0",
    "cspell-cli": "^10.0.1",
    "dedent-js": "^1.0.1",
    "eslint": "^10.5.0",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-format": "^2.0.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "kleur": "^4.1.5",
    "lightningcss": "^1.32.0",
    "pagefind": "^1.5.2",
    "prettier": "^3.8.4",
    "prettier-plugin-fhirpath": "^0.0.1-alpha-2",
    "tsm": "^2.3.0",
    "typescript": "^6.0.3"
  }
}