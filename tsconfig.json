{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": "src",
    "paths": {
      "#assets/*": [
        "assets/*"
      ],
      "#components/*": [
        "components/*"
      ],
      "#layouts/*": [
        "layouts/*"
      ],
      "#utils/*": [
        "utils/*"
      ]
    },
    "allowJs": true,
    "strictNullChecks": true,
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "plugins": [
      {
        "name": "@astrojs/ts-plugin"
      }
    ]
  },
  "include": [
    ".astro/types.d.ts",
    "**/*"
  ],
  "exclude": [
    "dist",
    "src/assets/uswds"
  ]
}